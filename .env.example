# === Required ===
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# === Database (Railway auto-sets DATABASE_URL) ===
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# === Business Info (fallback — primary config is in admin Settings page) ===
BUSINESS_NAME=VehicleRent Pro
BUSINESS_PHONE=+91 99999 99999
BUSINESS_EMAIL=info@example.com
BUSINESS_ADDRESS=Your City, State, India
WHATSAPP_NUMBER=919999999999

# === Email (for enquiry notifications) ===
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@yourdomain.com
NOTIFICATION_EMAIL=admin@yourdomain.com

# === CSRF (add your Railway domain) ===
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# === Railway (auto-set by Railway) ===
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
# RAILWAY_VOLUME_MOUNT_PATH=/data
# PORT=8000
